# OpenRouter credentials
# Sign up at https://openrouter.ai and generate a key.
# Default model is Claude 3.5 Haiku (paid — topping up ~$5 of credits is
# enough for hundreds of conversations). To use a free model instead,
# uncomment the OPENROUTER_MODEL line below.

OPENROUTER_API_KEY=sk-or-v1-YOUR-KEY-HERE

# Optional — overrides the default model from application.yml.
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
